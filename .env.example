# Copy file này thành .env và điền giá trị thực

ANTHROPIC_API_KEY=sk-ant-...

# Model (tùy chọn, mặc định: claude-sonnet-4-5)
MODEL=claude-sonnet-4-5

# Đường dẫn CSV knowledge base
CSV_PATH=data/canned_responses.csv

# Thư mục lưu lịch sử ticket
HISTORY_DIR=history

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
